{
  "manifest_version": 3,
  "name": "Cena mobilna na Booking",
  "version": "1.0.0",
  "version_name": "1.0 (zweryfikowane na booking.com, Gdansk)",
  "description": "Sprawdza, czy ta sama oferta na Booking.com ma nizsza cene dla urzadzen mobilnych, i pokazuje roznice bezposrednio na stronie. Rozroznia sesje zalogowana (z Genius) i niezalogowana.",
  "author": "Jan Malinowski",
  "homepage_url": "https://github.com/janekmalinowski-hub",
  "permissions": [
    "declarativeNetRequest",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.booking.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.booking.com/hotel/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Cena mobilna na Booking",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
